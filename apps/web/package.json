{
  "name": "storybook-web",
  "version": "0.1.0",
  "private": true,
  "engines": { "node": ">=18.x" },
  "scripts": {
    "dev": "ulimit -n 65536 2>/dev/null || true && CHOKIDAR_USEPOLLING=1 next dev -p 4050",
    "build": "prisma generate --schema=../../prisma/schema.prisma && next build",
    "start": "next start -p 4050",
    "lint": "next lint",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^5.22.0",
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-color": "^2.27.1",
    "@tiptap/extension-font-family": "^2.27.1",
    "@tiptap/extension-image": "^2.27.1",
    "@tiptap/extension-text-align": "^2.27.1",
    "@tiptap/extension-text-style": "^2.27.1",
    "@tiptap/extension-underline": "^2.27.1",
    "@tiptap/pm": "^2.1.13",
    "@tiptap/react": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "prisma": "^5.22.0",
    "typescript": "^5.3.3"
  }
}
