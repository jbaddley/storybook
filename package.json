{
  "name": "storybook-editor",
  "version": "1.0.0",
  "description": "Book editor with LLM integration for story consistency and writing assistance",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"wait-on http://localhost:4200 && npm run start:dev\" --kill-others-on-fail",
    "dev:main": "cross-env NODE_ENV=development webpack --config webpack.main.config.js --mode development --watch",
    "dev:renderer": "cross-env NODE_ENV=development webpack serve --config webpack.renderer.config.js --mode development",
    "start:dev": "cross-env NODE_ENV=development electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "start": "electron .",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "postinstall": "prisma generate",
    "web:dev": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "web:start": "npm run start --prefix apps/web",
    "pdf:test": "node scripts/pdf-export-test.js",
    "pdf:verify": "node scripts/verify-pdf-font.js scripts/output/test-export.pdf 20"
  },
  "keywords": [
    "book-editor",
    "electron",
    "llm",
    "writing-assistant"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "buffer": "^6.0.3",
    "chokidar": "^3.6.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-reloader": "^1.2.3",
    "eslint": "^8.54.0",
    "html-webpack-plugin": "^5.5.3",
    "node-loader": "^2.1.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.18.0",
    "prisma": "^5.22.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.4",
    "@codemirror/view": "^6.21.3",
    "@prisma/client": "^5.22.0",
    "@tiptap/core": "^2.1.13",
    "@tiptap/extension-color": "^2.27.1",
    "@tiptap/extension-font-family": "^2.27.1",
    "@tiptap/extension-image": "^2.27.1",
    "@tiptap/extension-placeholder": "^3.14.0",
    "@tiptap/extension-text-align": "^2.27.1",
    "@tiptap/extension-text-style": "^2.27.1",
    "@tiptap/extension-underline": "^2.27.1",
    "@tiptap/pm": "^2.1.13",
    "@tiptap/react": "^2.1.13",
    "@tiptap/starter-kit": "^2.1.13",
    "@uiw/react-codemirror": "^4.21.21",
    "docx": "^8.5.0",
    "dotenv": "^17.2.3",
    "electron-store": "^11.0.2",
    "googleapis": "^166.0.0",
    "jszip": "^3.10.1",
    "marked": "^11.1.1",
    "openai": "^6.15.0",
    "puppeteer-core": "^21.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "turndown": "^7.1.3",
    "zustand": "^4.4.7"
  }
}
